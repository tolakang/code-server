# Mobile Code Server Environment Variables
# Copy this file to .env and customize as needed

# Server Configuration
HOST=0.0.0.0
PORT=8080
NODE_ENV=production

# Authentication
AUTH_TYPE=none
# AUTH_TYPE=password
# AUTH_TYPE=github

# GitHub OAuth (if AUTH_TYPE=github)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mobile_code_server

# Redis Configuration (for sessions and real-time features)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Code Server Configuration
CODE_SERVER_HOST=127.0.0.1
CODE_SERVER_PORT=8081
CODE_SERVER_AUTH=none

# Security
JWT_SECRET=your_jwt_secret_key_here
SESSION_SECRET=your_session_secret_key_here

# AI Features
AI_PROVIDER=opencode
# AI_PROVIDER=claude
# AI_PROVIDER=codex
# AI_PROVIDER=gemini

# MCP Server Configuration
MCP_SERVER_ENABLED=true
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8082

# File Upload Configuration
FILE_UPLOAD_SIZE_LIMIT=10485760 # 10MB
FILE_UPLOAD_TYPES=image/*,application/*,text/*

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature Flags
FEATURE_TEAMS=true
FEATURE_NOTIFICATIONS=true
FEATURE_AUDIT_LOGS=true
FEATURE_MULTI_USER=true
FEATURE_WORKSPACE_TEMPLATES=true
FEATURE_AI_ASSISTANT=true
FEATURE_MCP_SERVER=true

# Docker Configuration
DOCKER_IMAGE=tolakang/mobile-code-server:latest
DOCKER_NETWORK=mobile-code-server-net

# Dokploy Configuration
DOKPLOY_APP_NAME=mobile-code-server
DOKPLOY_DOMAIN=code.yourdomain.com
DOKPLOY_SSL_ENABLED=true

# Email Configuration (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=notifications@mobile-code-server.com

# Required: Set this to true after configuring your environment
CONFIGURED=false