# Mobile Code Server Environment Variables
# Copy this file to .env and customize as needed.
#
# Most code-server configuration is done via CLI args in the Dockerfile CMD.
# To change code-server settings, edit the CMD line in docker/Dockerfile.

# =============================================================================
# Server / Runtime
# =============================================================================

NODE_ENV=production
HOST=0.0.0.0
PORT=8080

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================

DB_HOST=your-dokploy-db-service-name
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_NAME=mobile_code_server

# =============================================================================
# Authentication
# =============================================================================
# Set to "password" to require a password for code-server access.
# When set to "none", code-server is accessible without authentication.

AUTH_TYPE=none
# AUTH_TYPE=password

# =============================================================================
# Security
# =============================================================================
# Generate strong random values before enabling auth in production.

JWT_SECRET=change_me_to_a_random_string
SESSION_SECRET=change_me_to_a_random_string

# =============================================================================
# code-server Configuration
# =============================================================================
# These are configured as CLI args in docker/Dockerfile CMD, not env vars.
# To change them, edit the CMD line:
#   --bind-addr 127.0.0.1:8081  (internal only, proxied by nginx)
#   --auth none                  (authentication mode)
#   --disable-telemetry          (telemetry toggle)
#   .                            (workspace directory)

CODE_SERVER_HOST=127.0.0.1
CODE_SERVER_PORT=8081

# =============================================================================
# AI Features
# =============================================================================

AI_PROVIDER=opencode
# AI_PROVIDER=claude
# AI_PROVIDER=gemini

# =============================================================================
# MCP Server
# =============================================================================

MCP_SERVER_ENABLED=true
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8082

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=info
