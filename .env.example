# Mobile Code Server Environment Variables
# Copy this file to .env and customize as needed.
#
# When deploying on Dokploy with a managed database, set these
# in the Dokploy UI (Settings → Environment Variables). Dokploy
# writes them to .env and Docker Compose injects them via env_file.

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
# Option 1: Use DATABASE_URL (recommended for Dokploy managed DB)
# DATABASE_URL=postgresql://user:password@host:port/database_name
#
# Option 2: Use individual vars
DB_HOST=your-dokploy-db-service-name
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_NAME=mobile_code_server

# =============================================================================
# Server / Runtime
# =============================================================================
PORT=8080
CODE_SERVER_INTERNAL_PORT=3000
NODE_ENV=production

# =============================================================================
# Authentication
# =============================================================================
AUTH_TYPE=none

# =============================================================================
# Security
# =============================================================================
JWT_SECRET=change_me_to_a_random_string
SESSION_SECRET=change_me_to_a_random_string

# =============================================================================
# AI Features
# =============================================================================
AI_PROVIDER=opencode

# =============================================================================
# MCP Server
# =============================================================================
MCP_SERVER_ENABLED=true
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8082

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info
