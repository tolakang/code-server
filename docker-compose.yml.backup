version: '3.8'

services:
  code-server:
    build:
      context: .
      dockerfile: docker/Dockerfile
    ports:
      - "8080:8080"
    volumes:
      - ./project:/home/coder/project:cached
      - ./data:/home/coder/.local/share/code-server:cached
      - ./config:/home/coder/.config/code-server:cached
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=UTC
    restart: unless-stopped

networks:
  default:
    name: mobile-code-server-net
    driver: bridge